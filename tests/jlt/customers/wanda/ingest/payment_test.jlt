# 付费事件，currencytype取值，不在标准付费CNY，USD范围内
{
  "appid": "APPID",
  "xcontext": {
    "idfa": "example_idfa",
    "idfv": "example_idfv",
    "caid": "example_caid",
    "installid": "example_installid",
    "transactionid":"example_transactionid",
    "paymenttype":"wechatpay",
    "currencytype":"XXX",
    "currencyamount":123,
    "os": "ios",
    "os_version": "15.0",
    "brand": "apple",
    "channelid": "example_channelid",
    "model": "example_model",
    "pkgname": "example_pkgname"
  },
  "xwhat": "payment",
  "xwhen": 1718255925637,
  "xwho": "someoneelse"
}
----
fail
field `xcontext.currencytype` must be one of [JPY, EUR, BRL, HKD, TWD, COP, MXN, CHF, CAD, CLP, AUD, PEN, GBP, CRC, PLN, PYG, BOB, QAR, ILS, SEK, RUB, CNY, ZAR, SGD, NZD, BGN, LKR, IQD, TRY, AED, DZD, EGP, IDR, INR, NGN, NOK, PHP, PKR, THB, UAH, VND]

