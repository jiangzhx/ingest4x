# 付费事件，currencyamount的值类型，不是数值
{
  "appid": "APPID",
  "xcontext": {
    "idfa": "example_idfa",
    "idfv": "example_idfv",
    "caid": "example_caid",
    "installid": "example_installid",
    "transactionid":"example_transactionid",
    "paymenttype":"wechatpay",
    "currencytype":"CNY",
    "currencyamount":"123",
    "paymentstatus": true,
    "os": "ios",
    "os_version": "15.0",
    "brand": "apple",
    "channelid": "example_channelid",
    "model": "example_model",
    "pkgname": "example_pkgname"
  },
  "xwhat": "payment",
  "xwhen": 1718255925637,
  "xwho": "someoneelse"
}
----
fail
field `xcontext.currencyamount` expected type `Number`

