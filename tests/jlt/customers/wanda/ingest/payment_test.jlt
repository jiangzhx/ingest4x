# 付费事件，缺乏transactionid属性
{
  "appid": "APPID",
  "xcontext": {
    "idfa": "example_idfa",
    "idfv": "example_idfv",
    "caid": "example_caid",
    "installid": "example_installid",
    "os": "ios",
    "os_version": "15.0",
    "brand": "apple",
    "channelid": "example_channelid",
    "model": "example_model",
    "pkgname": "example_pkgname"
  },
  "xwhat": "payment",
  "xwhen": 1718255925637,
  "xwho": "someoneelse"
}
----
fail
missing required field `xcontext.transactionid`

